# ── Local scratch / personal data (never committed) ─────────────────────
# Exported text replacements are personal data; keep the whole temp tree out.
temp/

# ── ask-self RAG artifacts ──────────────────────────────────────────────

# Per-DB sidecars — never commit these in ANY mode, including alongside the
# committed portable index under ask_self/index/
*__embed_cache.sqlite
*__events.jsonl

# Portable mode: the committed index IS tracked — do NOT ignore
# ask_self/index/fast-key-replacement-macos.sqlite

# ── Build / OS artifacts ────────────────────────────────────────────────
.build/
.swiftpm/
macOS/dist/
.DS_Store
__pycache__/
*.pyc
keyboard text replacement
.claude/settings.json
